<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Eyewitness Report! · Lesson 6 (writing)</title>
<link rel="preconnect" href="https://cdn.jsdelivr.net">
<link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" rel="stylesheet">
<style>
  :root{
    --ink:#0e1530; --paper:#f5eddb; --paper-line:#e2d6ba;
    --tape:#f3c44b; --red:#e23b46; --blue:#2f6fed; --green:#27c08a;
    --skin:#f2c89c; --display:'Pretendard',system-ui,sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{font-family:var(--display); background:radial-gradient(1200px 800px at 50% -10%, #1d2a5e 0%, var(--ink) 55%, #080c1d 100%); color:#fff; overflow:hidden; user-select:none;}
  .wrap{height:100%; display:flex; flex-direction:column;}
  .hidden{display:none !important;}

  /* INTRO */
  #intro{height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:24px; position:relative; overflow:hidden;}
  #intro::before{content:''; position:absolute; inset:-40%; background:conic-gradient(from 0deg, transparent 0 70%, rgba(226,59,70,.22) 78%, transparent 86%, rgba(47,111,237,.22) 94%, transparent 100%); animation:spin 6s linear infinite; pointer-events:none;}
  @keyframes spin{to{transform:rotate(360deg)}}
  .badge{font-size:clamp(56px,12vw,96px); filter:drop-shadow(0 6px 14px rgba(0,0,0,.5)); animation:bob 2.4s ease-in-out infinite;}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
  .case-tag{font-size:clamp(13px,2.6vw,16px); letter-spacing:.32em; color:var(--tape); font-weight:700; margin-bottom:10px;}
  #intro h1{font-size:clamp(34px,8vw,70px); font-weight:900; line-height:.98; letter-spacing:-.01em; text-shadow:0 4px 0 #000a, 0 0 30px rgba(47,111,237,.35);}
  #intro h1 .y{color:var(--tape);}
  .sub{margin:14px 0 30px; color:#c3cbe6; font-size:clamp(15px,3.6vw,20px); max-width:580px;}
  .sub b{color:#fff;}
  .btn{font-family:var(--display); font-weight:800; cursor:pointer; border:none; border-radius:999px; transition:transform .12s, box-shadow .12s, filter .12s;}
  .btn:active{transform:translateY(2px) scale(.98);}
  .btn-start{font-size:clamp(18px,4.6vw,24px); padding:16px 44px; color:#1a1206; background:linear-gradient(180deg,#ffd968,var(--tape)); box-shadow:0 8px 0 #a97b14, 0 14px 26px rgba(0,0,0,.4);}
  .btn-start:active{box-shadow:0 3px 0 #a97b14;}
  .intro-tip{margin-top:26px; font-size:13px; color:#8a93b8;}

  /* HEADER */
  header{display:flex; align-items:center; gap:10px; padding:10px 14px; background:rgba(8,12,28,.6); border-bottom:1px solid rgba(255,255,255,.08); backdrop-filter:blur(6px); flex-wrap:wrap;}
  .h-left{display:flex; align-items:center; gap:10px; flex:1; min-width:0;}
  .stage-pill{font-weight:900; font-size:clamp(15px,3.4vw,19px); color:#fff; background:var(--blue); padding:6px 14px; border-radius:10px; white-space:nowrap; box-shadow:0 3px 0 #1f4cb0;}
  .progress{flex:1; height:10px; background:rgba(255,255,255,.12); border-radius:999px; overflow:hidden; min-width:80px;}
  .progress > i{display:block; height:100%; width:0; background:linear-gradient(90deg,var(--tape),#ffe08a); transition:width .4s;}
  .score{font-weight:800; font-size:14px; color:var(--tape); white-space:nowrap;}
  .icon-btn{font-family:var(--display); font-weight:800; font-size:14px; cursor:pointer; color:#0e1530; padding:8px 14px; border-radius:10px; border:none; background:#ffd968; box-shadow:0 3px 0 #b78f23;}
  .icon-btn.ghost{background:rgba(255,255,255,.12); color:#fff; box-shadow:0 3px 0 rgba(0,0,0,.3);}
  .icon-btn:active{transform:translateY(2px); box-shadow:none;}
  .icon-btn:disabled{opacity:.45; box-shadow:none; cursor:default;}

  /* SCENE */
  #scene{flex:1; display:flex; flex-direction:column; align-items:center; padding:14px; overflow-y:auto;}
  .stage-area{width:100%; max-width:720px;}

  /* WALK-BY */
  .walk{position:relative; width:100%; height:clamp(260px,46vh,360px); overflow:hidden; border-radius:18px; background:linear-gradient(180deg,#27376e 0%, #1a2348 70%, #141b3a 100%); display:flex; flex-direction:column; box-shadow:inset 0 0 60px rgba(0,0,0,.4);}
  .walk-caption{flex:none; padding:12px 14px 8px; text-align:center; font-weight:800; color:#dfe5ff; font-size:clamp(15px,3.6vw,19px); text-shadow:0 2px 6px rgba(0,0,0,.5); z-index:3;}
  .walk-stage{position:relative; flex:1; overflow:hidden; display:flex; align-items:flex-end; justify-content:center;}
  .street{position:absolute; bottom:0; left:0; right:0; height:34%; background:linear-gradient(180deg,#2c2f44,#1b1d2c); border-top:3px solid rgba(255,255,255,.1);}
  .street::after{content:''; position:absolute; top:46%; left:0; right:0; height:5px; background:repeating-linear-gradient(90deg, var(--tape) 0 26px, transparent 26px 52px); opacity:.55;}
  .lamp{position:absolute; bottom:34%; font-size:30px; opacity:.5;}
  .figure{position:relative; z-index:2; height:clamp(118px,22vh,180px); margin-bottom:6%;}
  .figure svg{display:block; height:100%; width:auto;}
  .figure.walk-anim{animation:walkBy 5.4s ease-in-out forwards;}
  @keyframes walkBy{0%{transform:translateX(-72vw)}36%{transform:translateX(0)}68%{transform:translateX(0)}100%{transform:translateX(76vw)}}

  /* POLICE ZONE */
  .police-zone{display:flex; flex-direction:column; align-items:center; gap:6px; margin:10px 0 4px;}
  .talker{font-size:clamp(46px,11vw,72px); line-height:1; filter:drop-shadow(0 8px 14px rgba(0,0,0,.5)); animation:bob 2.4s ease-in-out infinite;}
  .bubble{position:relative; background:var(--paper); color:#1d2235; border-radius:16px; padding:14px 20px; margin-top:6px; font-size:clamp(17px,4.2vw,24px); font-weight:800; text-align:center; line-height:1.3; box-shadow:0 8px 20px rgba(0,0,0,.35); max-width:560px;}
  .bubble::before{content:''; position:absolute; top:-11px; left:50%; transform:translateX(-50%); border-width:0 12px 12px; border-style:solid; border-color:transparent transparent var(--paper);}
  .bubble.pop{animation:pop .25s ease-out;}
  @keyframes pop{0%{transform:scale(.97)}60%{transform:scale(1.02)}100%{transform:scale(1)}}

  /* BUILDER */
  #builder{width:100%; max-width:720px; padding-bottom:14px;}
  .statement{background:var(--paper); color:#1d2235; border-radius:14px; padding:14px 16px; margin:10px 0 14px; box-shadow:0 8px 20px rgba(0,0,0,.3);}
  .statement.shake{animation:shake .45s;}
  @keyframes shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-8px)}40%{transform:translateX(8px)}60%{transform:translateX(-6px)}80%{transform:translateX(6px)}}
  .statement-head{font-size:12px; font-weight:900; letter-spacing:.12em; color:#9a7a1e; margin-bottom:8px;}
  .statement p{font-size:clamp(17px,4.3vw,24px); font-weight:700; line-height:1.95; color:#1d2235;}
  .blank-slot{display:inline-block; min-width:64px; padding:1px 12px; margin:0 2px; border:none; border-bottom:3px solid #b08968; background:rgba(176,137,104,.16); color:#1d4ed8; font-weight:800; font-family:var(--display); font-size:1em; cursor:pointer; border-radius:6px 6px 0 0; transition:.12s; vertical-align:baseline;}
  .blank-slot.active{background:rgba(243,196,75,.5); border-bottom-color:#b8860b; box-shadow:0 0 0 2px rgba(243,196,75,.55);}
  .wordbank{background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.12); border-radius:14px; padding:12px 14px; margin:0 0 6px;}
  .wb-label{font-size:13px; font-weight:800; color:var(--tape); margin-bottom:10px;}
  .blank{color:#b08968; text-decoration:underline; text-underline-offset:3px;}
  .fill{color:#1d4ed8; font-weight:800;}
  .groups{display:grid; grid-template-columns:1fr 1fr; gap:10px 16px; align-items:start;}
  .col{display:flex; flex-direction:column; gap:12px;}
  @media (max-width:560px){ .groups{grid-template-columns:1fr;} }
  .group h3{font-size:13px; font-weight:800; letter-spacing:.04em; color:#cfd6f2; margin:4px 0 8px; display:flex; align-items:center; gap:6px; text-transform:capitalize;}
  .asked-note{font-size:13px; font-weight:700; color:#0e1530; background:rgba(243,196,75,.9); border-radius:8px; padding:7px 10px; margin-bottom:9px;}
  .asked-note b{text-transform:capitalize;}
  .recap{display:inline-block; margin-top:6px; font-size:.92em; color:#5a4a22; text-transform:capitalize;}
  .chips{display:flex; flex-wrap:wrap; gap:8px;}
  .chip{display:inline-flex; align-items:center; gap:9px; padding:12px 18px; border-radius:12px; border:2px solid rgba(255,255,255,.16); background:rgba(255,255,255,.06); color:#fff; font-weight:700; font-size:18px; cursor:pointer; font-family:var(--display); transition:.12s; text-transform:capitalize;}
  .chip:hover{border-color:var(--tape);}
  .chip.sel{border-color:var(--tape); background:rgba(243,196,75,.22); box-shadow:0 0 0 3px rgba(243,196,75,.22);}
  .sw{width:18px; height:18px; border-radius:4px; box-shadow:0 0 0 1px rgba(0,0,0,.35) inset;}
  .builder-actions{display:flex; align-items:center; justify-content:space-between; gap:10px; margin-top:14px; flex-wrap:wrap;}
  .btn-submit{font-size:clamp(16px,4.2vw,21px); padding:14px 30px; color:#fff; background:linear-gradient(180deg,#34d39a,var(--green)); box-shadow:0 6px 0 #1c8a64, 0 12px 22px rgba(0,0,0,.4);}
  .btn-submit:active{box-shadow:0 2px 0 #1c8a64;}
  .btn-submit:disabled{filter:grayscale(.7) brightness(.8); box-shadow:0 6px 0 #1c8a64; cursor:default;}
  .chances{display:flex; align-items:center; justify-content:center; gap:9px; margin:14px 0 2px;}
  .chances .ch-label{font-size:13px; font-weight:800; color:#cfd6f2;}
  .chances .dot{width:16px; height:16px; border-radius:50%; background:var(--blue); box-shadow:0 0 0 3px rgba(47,111,237,.25); transition:.2s;}
  .chances .dot.lost{background:transparent; box-shadow:none; position:relative;}
  .chances .dot.lost::after{content:'✕'; position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); color:var(--red); font-size:18px; font-weight:900;}

  /* PEEK */
  #peek{position:fixed; inset:0; z-index:45; display:flex; flex-direction:column; align-items:center; justify-content:center; background:rgba(6,9,22,.84);}
  #peek .figure{height:clamp(190px,42vh,300px); width:auto; margin:0; animation:none;}
  #peek .peek-tag{font-weight:800; color:#dfe5ff; margin-top:10px; font-size:16px;}

  /* OVERLAY */
  #overlay{position:fixed; inset:0; z-index:50; display:flex; flex-direction:column; align-items:center; justify-content:center; background:rgba(6,9,22,.85); backdrop-filter:blur(3px); padding:20px; text-align:center;}
  #overlay.gameover{background:radial-gradient(ellipse at center, rgba(122,22,30,.88), rgba(6,9,22,.94));}
  .result-big{font-size:clamp(42px,11vw,82px); font-weight:900; color:var(--green); text-shadow:0 4px 0 #000a, 0 0 30px rgba(39,192,138,.5); animation:gotcha .55s ease-out;}
  .result-big.fail{color:#ff7a59; text-shadow:0 4px 0 #000a, 0 0 30px rgba(255,122,89,.5);}
  @keyframes gotcha{0%{transform:scale(0) rotate(-8deg);opacity:0}55%{transform:scale(1.25) rotate(3deg)}100%{transform:scale(1) rotate(0);opacity:1}}
  .arrest{position:relative; width:min(340px,82vw); height:150px; margin:14px 0 4px; overflow:hidden;}
  .arrest .perp{position:absolute; left:14%; bottom:0; width:74px;}
  .arrest .car{position:absolute; left:58%; bottom:4px; font-size:52px;}
  .arrest.go .perp{animation:drag 1.4s ease-in .15s forwards;}
  .arrest.go .car{animation:carIn 1.4s ease-in forwards;}
  @keyframes drag{to{left:120%; transform:rotate(14deg); opacity:0;}}
  @keyframes carIn{0%{left:120%;}60%{left:56%;}100%{left:56%;}}
  .arrest .laugh{position:absolute; left:50%; top:-8px; transform:translateX(-50%); font-size:38px;}
  .arrest.escape .laugh{animation:bob 1s ease-in-out 3;}
  .arrest .dust{position:absolute; bottom:8px; left:34%; font-size:38px; opacity:0;}
  .arrest.escape.go .perp{left:42%; animation:taunt .55s ease-in-out 1, dashOff 1s ease-in .55s forwards;}
  .arrest.escape.go .dust{animation:dustPuff 1s ease-in .55s forwards;}
  @keyframes taunt{0%,100%{transform:rotate(0)}25%{transform:rotate(-9deg) scale(1.05)}75%{transform:rotate(9deg) scale(1.05)}}
  @keyframes dashOff{to{left:120%; opacity:0;}}
  @keyframes dustPuff{0%{opacity:.9; left:34%}100%{opacity:0; left:72%}}
  .case-stars{font-size:clamp(34px,9vw,54px); letter-spacing:6px; margin:2px 0 8px; animation:pop .4s ease-out;}
  .case-stars .star-empty{opacity:.32;}
  .result-sub{font-size:clamp(15px,3.6vw,19px); color:#cfd6f2; font-weight:700; margin-bottom:16px; max-width:560px;}
  .answer-card{background:var(--paper); color:#1d2235; border-radius:12px; padding:12px 16px; margin-bottom:16px; font-weight:700; font-size:clamp(14px,3.6vw,18px); line-height:1.5; max-width:520px; box-shadow:0 8px 20px rgba(0,0,0,.3);}
  .answer-card b{color:#1d4ed8;}
  .btn-next{font-size:clamp(17px,4.4vw,22px); padding:14px 40px; color:#fff; background:linear-gradient(180deg,#4d86ff,var(--blue)); box-shadow:0 7px 0 #1f4cb0, 0 12px 24px rgba(0,0,0,.4);}
  .btn-next:active{box-shadow:0 2px 0 #1f4cb0;}
  .final-emoji{font-size:clamp(60px,15vw,110px); animation:bob 2s ease-in-out infinite;}
  .stamp{font-family:var(--display); font-weight:900; letter-spacing:.1em; text-transform:uppercase; color:var(--red); border:5px solid var(--red); border-radius:12px; padding:7px 22px; font-size:clamp(22px,6.5vw,40px); transform:rotate(-9deg); opacity:.94; margin-bottom:10px; box-shadow:0 0 0 2px rgba(226,59,70,.22) inset; animation:stamp .5s cubic-bezier(.2,1.5,.5,1) both;}
  @keyframes stamp{0%{transform:rotate(-9deg) scale(2.6); opacity:0}55%{opacity:1}100%{transform:rotate(-9deg) scale(1); opacity:.94}}
  .stars{font-size:clamp(30px,8vw,52px); letter-spacing:6px; margin:6px 0;}
  .final-score{font-size:clamp(40px,10vw,72px); font-weight:900; color:var(--tape);}
  .final-score small{font-size:.4em; color:#c3cbe6; font-weight:700;}
  .confetti{position:fixed; inset:0; pointer-events:none; overflow:hidden; z-index:60;}
  .confetti i{position:absolute; top:-16px; width:10px; height:14px; opacity:.92; animation:fall linear forwards;}
  @keyframes fall{to{transform:translateY(110vh) rotate(720deg);}}

  @media (prefers-reduced-motion: reduce){ *{animation-duration:.001ms !important; animation-iteration-count:1 !important;} }
</style>
</head>
<body>
<div class="wrap">

  <section id="intro">
    <div class="badge">🕵️</div>
    <div class="case-tag">CASE FILE · LESSON 6 · WRITING</div>
    <h1>EYEWITNESS <span class="y">REPORT!</span></h1>
    <p class="sub">A suspect walks by. Watch closely!<br>Then tell the police what they looked like.<br>
      <b>"He has black hair. She is wearing a red jacket."</b></p>
    <button class="btn btn-start" onclick="startGame()">🔍 Start the case</button>
    <p class="intro-tip">머리색·눈동자색·안경 + 경찰이 묻는 옷(shirt/jacket/pants) 색을 골라 진술하세요 · 옷 셋 다 기억! · 10 cases</p>
  </section>

  <section id="game" class="wrap hidden">
    <header>
      <div class="h-left">
        <span class="stage-pill" id="stagePill">CASE 1/10</span>
        <div class="progress"><i id="progBar"></i></div>
        <span class="score" id="scoreTxt">⭐ 0</span>
      </div>
      <button class="icon-btn ghost" id="soundBtn" onclick="toggleSound()">🔊</button>
    </header>

    <div id="scene">
      <div class="stage-area">
        <div class="walk hidden" id="walkArea">
          <div class="walk-caption" id="walkCaption">🚶 A suspect is passing by… watch closely!</div>
          <div class="walk-stage">
            <span class="lamp" style="left:8%">🏮</span>
            <span class="lamp" style="right:8%">🏮</span>
            <div class="street"></div>
            <div class="figure" id="figure"></div>
          </div>
        </div>

        <div class="police-zone hidden" id="policeZone">
          <div class="talker" id="talker">👮</div>
          <div class="bubble pop" id="bubble">…</div>
        </div>

        <div id="builder" class="hidden"></div>
      </div>
    </div>
  </section>

  <section id="peek" class="hidden">
    <div class="figure"></div>
    <div class="peek-tag">👀 Quick look!</div>
  </section>

  <section id="overlay" class="hidden"></section>
</div>

<script>
/* ===== data ===== */
const hairColors  = ['black','blonde','brown','red'];
const eyeColors   = ['blue','brown','green'];
const clothItems  = ['shirt','pants','jacket'];
const clothColors = ['red','blue','green','yellow','white','black'];
const ITEM_EMOJI  = {shirt:'👕', pants:'👖', jacket:'🧥'};

const HAIR_HEX  = {black:'#2a2a31', blonde:'#e3b23c', brown:'#5b3a1e', red:'#b8431f'};
const EYE_HEX   = {blue:'#2f6fed', brown:'#7c4a1e', green:'#1f9d52'};
const CLOTH_HEX = {red:'#e23b46', blue:'#2f6fed', green:'#27a35f', yellow:'#f4c430', white:'#f4f4f6', black:'#23242c'};
const SKIN='#f2c89c';

const POLICE_EMOJI = g => g==='female' ? '👮‍♀️' : '👮‍♂️';

let stages=[], cur=0, score=0, wrong=0, locked=false, escapedCount=0;
let soundOn=true, voices=[], flowToken=0, peeksLeft=1, selection={};

/* ===== utils ===== */
const rand = a => a[Math.floor(Math.random()*a.length)];
const wait = ms => new Promise(r=>setTimeout(r,ms));

function pick3Distinct(arr){ const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a.slice(0,3); }
function buildStage(i){
  const gender = i%2===0 ? 'male' : 'female';
  const policeGender = i%2===0 ? 'female' : 'male';
  const P = gender==='male' ? 'He' : 'She';
  const [cs,cj,cp]=pick3Distinct(clothColors);
  const suspect = { hair:rand(hairColors), eyes:rand(eyeColors), glasses:Math.random()<.5, clothes:{shirt:cs,jacket:cj,pants:cp}, gender };
  const askedItem = rand(clothItems);
  return {gender, P, policeGender, askedItem, suspect};
}
function generateStages(){ stages=[]; for(let i=0;i<10;i++) stages.push(buildStage(i)); }

/* ===== full-body suspect figure ===== */
function suspectFigure(s, gender, showKey){
  const hair=HAIR_HEX[s.hair], eye=EYE_HEX[s.eyes];
  const shirtC=CLOTH_HEX[s.clothes.shirt], jacketC=CLOTH_HEX[s.clothes.jacket], pantsC=CLOTH_HEX[s.clothes.pants];
  const st='stroke="rgba(0,0,0,.28)" stroke-width="1.4"';
  const backHair = gender==='female'
    ? `<path d="M40 62 Q36 22 60 18 Q84 22 80 62 L80 74 Q78 52 70 50 L50 50 Q42 52 42 74 Z" fill="${hair}"/>` : '';
  const topHair = gender==='female'
    ? `<path d="M41 44 Q40 20 60 19 Q80 20 79 44 Q71 31 60 31 Q49 31 41 44 Z" fill="${hair}"/>`
    : `<path d="M42 44 Q41 22 60 21 Q79 22 78 44 Q69 32 60 32 Q51 32 42 44 Z" fill="${hair}"/>`;
  const glasses = s.glasses ? `
    <g fill="rgba(255,255,255,.18)" stroke="#23242c" stroke-width="2.4" stroke-linejoin="round">
      <rect x="44" y="40" width="14" height="11" rx="3.5"/>
      <rect x="62" y="40" width="14" height="11" rx="3.5"/>
      <path d="M58 45 h4"/>
    </g>` : '';
  const key = showKey ? `
    <g font-family="'Pretendard', system-ui, sans-serif" font-weight="800" font-size="13">
      <rect x="120" y="44" width="78" height="126" rx="12" fill="rgba(10,16,40,.62)" stroke="rgba(255,255,255,.2)"/>
      <rect x="131" y="58" width="18" height="18" rx="4" fill="${shirtC}" stroke="rgba(0,0,0,.35)"/>
      <text x="155" y="72" fill="#fff">shirt</text>
      <rect x="131" y="100" width="18" height="18" rx="4" fill="${jacketC}" stroke="rgba(0,0,0,.35)"/>
      <text x="155" y="114" fill="#fff">jacket</text>
      <rect x="131" y="142" width="18" height="18" rx="4" fill="${pantsC}" stroke="rgba(0,0,0,.35)"/>
      <text x="155" y="156" fill="#fff">pants</text>
    </g>` : '';
  const vb = showKey ? '0 0 204 210' : '0 0 120 210';
  return `
  <svg viewBox="${vb}" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="suspect">
    <!-- pants -->
    <rect x="48" y="136" width="12" height="58" rx="5" fill="${pantsC}" ${st}/>
    <rect x="60" y="136" width="12" height="58" rx="5" fill="${pantsC}" ${st}/>
    <ellipse cx="54" cy="196" rx="9" ry="5" fill="#1b1c24"/>
    <ellipse cx="66" cy="196" rx="9" ry="5" fill="#1b1c24"/>
    <!-- shirt (full torso base, wide centre stays visible) -->
    <rect x="40" y="74" width="40" height="66" rx="12" fill="${shirtC}" ${st}/>
    <!-- jacket sleeves -->
