/* ===== sentence helpers ===== */
function sentenceLines(a, st, span){
  const P=st.P, item=st.askedItem;
  const f = span ? (t=>`<span class="fill">${t}</span>`) : (t=>t);
  const blank = span ? '<span class="blank">____</span>' : '____';
  const hair = a.hair ? `${P} has ${f(a.hair)} hair.` : `${P} has ${blank} hair.`;
  const eyes = a.eyes ? `${P} has ${f(a.eyes)} eyes.` : `${P} has ${blank} eyes.`;
  const gl = ('glasses' in a) ? (a.glasses ? `${P} is wearing ${f('glasses')}.` : `${P} is ${f('not')} wearing glasses.`) : `${P} is wearing ${blank}.`;
  const colorPart = a.color ? f(a.color) : blank;
  const cl = item==='pants' ? `${P} is wearing ${colorPart} pants.` : `${P} is wearing a ${colorPart} ${item}.`;
  return [hair,eyes,gl,cl];
}

