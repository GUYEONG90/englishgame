function loadVoices(){ if('speechSynthesis' in window) voices=speechSynthesis.getVoices(); }
if('speechSynthesis' in window){ loadVoices(); speechSynthesis.onvoiceschanged=loadVoices; }
const FEM_HINT=/(female|woman|samantha|victoria|zira|susan|karen|moira|tessa|fiona|serena|allison|\bava\b|joanna|salli|kimberly|\bamy\b|emma|nicky|aria|jenny|sonia|google us english)/i;
const MALE_HINT=/(\bmale\b|\bman\b|daniel|david|\balex\b|fred|\btom\b|\bmark\b|aaron|arthur|george|oliver|rishi|\bguy\b|brian|matthew|\bryan\b|\beric\b)/i;
function pickVoice(){ return voices.find(v=>/en[-_]?US/i.test(v.lang)) || voices.find(v=>/^en/i.test(v.lang)) || null; }
function genderedVoice(g){ const en=voices.filter(v=>/^en/i.test(v.lang)); let v=null; if(g==='female') v=en.find(x=>FEM_HINT.test(x.name))||en.find(x=>!MALE_HINT.test(x.name)); else v=en.find(x=>MALE_HINT.test(x.name))||en.find(x=>!FEM_HINT.test(x.name)); return v||pickVoice(); }
function speak(text, opts={}){
  return new Promise(resolve=>{
    if(!soundOn || !('speechSynthesis' in window)){ setTimeout(resolve, Math.min(3200,800+text.length*42)); return; }
    try{ speechSynthesis.cancel(); const u=new SpeechSynthesisUtterance(text); let v=null,pitch=1;
      if(opts.gender==='female'){ v=genderedVoice('female'); pitch=1.28; }
      else if(opts.gender==='male'){ v=genderedVoice('male'); pitch=.85; }
      else v=pickVoice();
      if(v)u.voice=v; u.lang=(v&&v.lang)||'en-US'; u.rate=.86; u.pitch=pitch; let done=false;
      const fin=()=>{if(!done){done=true;resolve();}}; u.onend=fin; u.onerror=fin; speechSynthesis.speak(u); setTimeout(fin,1200+text.length*120);
    }catch(e){ resolve(); }
  });
}

/* ===== flow ===== */
function startGame(){
  generateStages(); cur=0; score=0; escapedCount=0;
  document.getElementById('intro').classList.add('hidden');
  document.getElementById('game').classList.remove('hidden');
  siren();
  playStage();
}

function setTalker(emoji){ document.getElementById('talker').textContent=emoji; }
function setBubble(text){ const b=document.getElementById('bubble'); b.textContent=text; b.classList.remove('pop'); void b.offsetWidth; b.classList.add('pop'); }
function updateScore(){ document.getElementById('scoreTxt').textContent=`⭐ ${score}`; }

function onceAnim(el){ return new Promise(res=>{ let done=false; const f=()=>{ if(!done){done=true; el.removeEventListener('animationend',f); res();} }; el.addEventListener('animationend',f,{once:true}); setTimeout(f,5600); }); }

async function playStage(){
  const token=++flowToken;
  const st=stages[cur];
  wrong=0; locked=false; peeksLeft=1; selection={};
  document.getElementById('stagePill').textContent=`CASE ${cur+1}/10`;
  document.getElementById('progBar').style.width=`${(cur/10)*100}%`;
  updateScore();
  document.getElementById('policeZone').classList.add('hidden');
  document.getElementById('builder').classList.add('hidden');
  const ov=document.getElementById('overlay'); ov.classList.add('hidden'); ov.classList.remove('gameover');

  // walk-by
  const walk=document.getElementById('walkArea'); walk.classList.remove('hidden');
  document.getElementById('walkCaption').textContent='🚶 A suspect is passing by… watch closely!';
  const fig=document.getElementById('figure');
  fig.innerHTML=suspectFigure(st.suspect, st.gender, true);
  fig.classList.remove('walk-anim'); void fig.offsetWidth; fig.classList.add('walk-anim');
  whooshBy();
  await onceAnim(fig);
  if(token!==flowToken) return;
  walk.classList.add('hidden');

  // meet police
  document.getElementById('policeZone').classList.remove('hidden');
  const itemQ = st.askedItem==='pants' ? 'are the pants' : `is the ${st.askedItem}`;
  const q = `What does the suspect look like? And what color ${itemQ}?`;
  setTalker(POLICE_EMOJI(st.policeGender));
  setBubble(q);
  await speak(q, {gender:st.policeGender});
  if(token!==flowToken) return;
  showBuilder();
}

const BLANKS=['hair','eyes','glasses','color'];
let activeBlank='hair';
function isFilled(k){ return k==='glasses' ? ('glasses' in selection) : !!selection[k]; }
function blankWord(k){
  if(k==='glasses') return ('glasses' in selection) ? (selection.glasses?'wearing':'not wearing') : '';
  return selection[k] || '';
}

function showBuilder(){
  selection={}; activeBlank='hair';
  const b=document.getElementById('builder');
  b.innerHTML=`
    <div class="statement" id="statement">
      <div class="statement-head">📝 Complete your statement — tap a blank, then pick a word</div>
      <p id="sentence"></p>
    </div>
    <div class="wordbank" id="wordbank">
      <div class="wb-label" id="wbLabel"></div>
      <div class="chips" id="wbChips"></div>
    </div>
    <div class="chances" id="chances"></div>
    <div class="builder-actions">
      <button class="icon-btn ghost" id="peekBtn" onclick="peek()">👀 See again (1)</button>
      <button class="btn btn-submit" id="submitBtn" onclick="submitStatement()" disabled>📣 Report to police</button>
    </div>`;
  b.classList.remove('hidden');
  renderSentence(); renderWordBank(); renderChances(); updateSubmit();
}

function renderSentence(){
  const st=stages[cur], P=st.P, item=st.askedItem;
  const slot=k=>`<button class="blank-slot${activeBlank===k?' active':''}" onclick="setActiveBlank('${k}')">${blankWord(k)}</button>`;
  const cloth = item==='pants'
    ? `${P} is wearing ${slot('color')} pants.`
    : `${P} is wearing a ${slot('color')} ${item}.`;
  document.getElementById('sentence').innerHTML =
    `${P} has ${slot('hair')} hair. ${P} has ${slot('eyes')} eyes. ${P} is ${slot('glasses')} glasses. ${cloth}`;
}

function setActiveBlank(k){ if(locked) return; activeBlank=k; renderSentence(); renderWordBank(); }

function renderWordBank(){
  const st=stages[cur], item=st.askedItem;
  let label='', opts=[];
  if(activeBlank==='hair'){ label='💇 Hair color'; opts=hairColors.map(v=>({v,hex:HAIR_HEX[v],txt:v})); }
  else if(activeBlank==='eyes'){ label='👁️ Eye color'; opts=eyeColors.map(v=>({v,hex:EYE_HEX[v],txt:v})); }
  else if(activeBlank==='glasses'){ label='👓 Glasses or not?'; opts=[{v:'wearing',txt:'👓 wearing'},{v:'not wearing',txt:'🚫 not wearing'}]; }
  else { label=`${ITEM_EMOJI[item]} ${item} color — remember all three!`; opts=clothColors.map(v=>({v,hex:CLOTH_HEX[v],txt:v})); }
  document.getElementById('wbLabel').textContent=label;
  document.getElementById('wbChips').innerHTML = opts.map(o=>
    `<button class="chip" onclick="fillBlank('${o.v}')">${o.hex?`<span class="sw" style="background:${o.hex}"></span>`:''}${o.txt}</button>`).join('');
}

function fillBlank(val){
  if(locked) return;
  if(activeBlank==='glasses') selection.glasses = (val==='wearing');
  else selection[activeBlank]=val;
  const next = BLANKS.find(k=>!isFilled(k));
  activeBlank = next || activeBlank;
  renderSentence(); renderWordBank(); updateSubmit();
}

function updateSubmit(){
  document.getElementById('submitBtn').disabled = !BLANKS.every(isFilled);
}
function renderChances(){
  const el=document.getElementById('chances'); if(!el) return;
  el.innerHTML='<span class="ch-label">🔎 Chances</span>';
  for(let i=0;i<3;i++){ const d=document.createElement('span'); d.className='dot'+(i<wrong?' lost':''); el.appendChild(d); }
}

function peek(){
  if(peeksLeft<=0 || locked) return;
  peeksLeft--;
  const btn=document.getElementById('peekBtn');
  btn.textContent=`👀 See again (${peeksLeft})`;
  if(peeksLeft<=0) btn.disabled=true;
  const p=document.getElementById('peek');
  p.querySelector('.figure').innerHTML=suspectFigure(stages[cur].suspect, stages[cur].gender, true);
  p.classList.remove('hidden');
  setTimeout(()=>p.classList.add('hidden'), 2200);
}

function submitStatement(){
  if(locked) return;
  const st=stages[cur], sp=st.suspect;
  let n=0;
  if(selection.hair!==sp.hair)n++;
  if(selection.eyes!==sp.eyes)n++;
  if(selection.glasses!==sp.glasses)n++;
  if(selection.color!==sp.clothes[st.askedItem])n++;

  if(n===0){
    locked=true; chime();
    const earned=3-wrong; score+=earned; updateScore();
    setTimeout(()=>showResult(st,earned), 500);
  }else{
    wrong++; buzz(); renderChances();
    const stEl=document.getElementById('statement'); stEl.classList.add('shake'); setTimeout(()=>stEl.classList.remove('shake'),450);
    if(wrong>=3){ suspectEscapes(st); return; }
    // fresh look for the next attempt
    peeksLeft=1;
    const pb=document.getElementById('peekBtn'); if(pb){ pb.disabled=false; pb.textContent='👀 See again (1)'; }
    const left=3-wrong;
    setBubble(`Hmm… ${n} detail${n>1?'s':''} don't match. ${left} ${left===1?'chance':'chances'} left!`);
  }
}

function showResult(st, earned){
  sirenShort(); handcuff();
  const meter='⭐'.repeat(earned)+`<span class="star-empty">${'☆'.repeat(3-earned)}</span>`;
  const note = earned===3 ? 'Perfect report! 🎯 +3 stars'
             : earned===2 ? 'Good report · +2 stars'
             : 'Caught — just in time · +1 star';
  const ov=document.getElementById('overlay'); ov.classList.remove('hidden');
  ov.innerHTML=`
    <div class="result-big">🎉 Gotcha!</div>
    <div class="arrest go">
      <div class="perp">${suspectFigure(st.suspect, st.gender)}</div>
      <div class="car">🚔</div>
    </div>
    <div class="case-stars">${meter}</div>
    <div class="result-sub">${note}</div>
    <button class="btn btn-next" onclick="nextStage()">${cur<9?'Next case ➜':'See results 🏆'}</button>`;
}

const TAUNTS=["Ha ha! Wrong description!","You'll never describe me!","So long, eyewitness!","Better look harder next time!","Nice try, detective!"];
const BOSS_TAUNTS=["Three wrong reports! The city is mine! 😈","You're off the case, detective!","The masterminds always win!","Hang up that badge!"];

function suspectEscapes(st){
  locked=true; escapedCount++;
  womp();
  setTalker(POLICE_EMOJI(st.policeGender));
  setBubble(`Oh no! ${st.P==='He'?'He':'She'} got away…`);
  if(escapedCount>=3) setTimeout(()=>showGameOver(st),1100);
  else setTimeout(()=>showEscape(st),1100);
}

function answerHTML(st){
  const sp=st.suspect;
  const correct={hair:sp.hair, eyes:sp.eyes, glasses:sp.glasses, color:sp.clothes[st.askedItem]};
  return sentenceLines(correct, st, true).join(' ');
}

function showEscape(st){
  const sp=st.suspect;
  const taunt=TAUNTS[Math.floor(Math.random()*TAUNTS.length)];
  const ov=document.getElementById('overlay'); ov.classList.remove('hidden');
  ov.innerHTML=`
    <div class="result-big fail">😈 Escaped!</div>
    <div class="arrest escape go">
      <div class="laugh">🤣</div>
      <div class="perp">${suspectFigure(st.suspect, st.gender)}</div>
      <div class="dust">💨</div>
    </div>
    <div class="result-sub">"${taunt}"</div>
    <div class="answer-card">Correct answer: ${answerHTML(st)}<br>
      <span class="recap">👕 ${sp.clothes.shirt} · 🧥 ${sp.clothes.jacket} · 👖 ${sp.clothes.pants}</span></div>
    <button class="btn btn-next" onclick="nextStage()">${cur<9?'Next case ➜':'See results 🏆'}</button>`;
  speak(taunt, {gender:st.gender});
}

function showGameOver(st){
  if('speechSynthesis' in window) speechSynthesis.cancel();
  gameOverSound();
  const taunt=BOSS_TAUNTS[Math.floor(Math.random()*BOSS_TAUNTS.length)];
  const caught=(cur+1)-escapedCount;
  const ov=document.getElementById('overlay'); ov.classList.remove('hidden'); ov.classList.add('gameover');
  ov.innerHTML=`
    <div class="stamp">Case Failed</div>
    <div class="final-emoji">🚨</div>
    <div class="result-big fail" style="font-size:clamp(38px,9.5vw,68px)">GAME OVER</div>
    <div class="result-sub">3 suspects escaped — the chief pulled you off the case.</div>
    <div class="result-sub" style="color:#ff7a59">"${taunt}"</div>
    <div class="final-score" style="font-size:clamp(24px,6.5vw,38px)">🟢 ${caught} caught &nbsp;·&nbsp; 🔴 ${escapedCount} escaped</div>
    <button class="btn btn-next" onclick="restart()">🔁 Try again</button>`;
  setTimeout(()=>speak(taunt,{gender:st.gender}),900);
}

function nextStage(){ cur++; if(cur>=10){ showFinal(); return; } playStage(); }

function showFinal(){
  if('speechSynthesis' in window) speechSynthesis.cancel();
  document.getElementById('progBar').style.width='100%';
  fanfare(); launchConfetti();
  const stars = score>=27?'⭐⭐⭐' : score>=18?'⭐⭐' : score>=1?'⭐':'·';
  const msg = score>=27?'Master Detective!' : score>=18?'Sharp eyewitness!' : score>=1?'Good start — try again!':'Look more carefully next time!';
  const stampTxt = escapedCount===0 ? 'Case Closed' : 'Case Report';
  const escLine = escapedCount>0 ? `<div class="result-sub" style="color:#ff7a59;margin:-8px 0 14px">🚨 ${escapedCount} suspect${escapedCount>1?'s':''} got away</div>` : '';
  const ov=document.getElementById('overlay'); ov.classList.remove('hidden');
  ov.innerHTML=`
    <div class="stamp">${stampTxt}</div>
    <div class="final-emoji">🏆</div>
    <div class="stars">${stars}</div>
    <div class="final-score">${score}<small>/30 ⭐</small></div>
    <div class="result-sub">${msg}</div>
    ${escLine}
    <button class="btn btn-next" onclick="restart()">🔁 Play again</button>`;
}

function restart(){ const ov=document.getElementById('overlay'); ov.classList.add('hidden'); ov.classList.remove('gameover'); startGame(); }
function toggleSound(){ soundOn=!soundOn; document.getElementById('soundBtn').textContent=soundOn?'🔊':'🔇'; if(!soundOn&&'speechSynthesis' in window) speechSynthesis.cancel(); }
</script>
</body>
</html>
